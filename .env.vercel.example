# Vercel Environment Variables
# Add these in your Vercel Project Settings > Environment Variables

# Application
APP_NAME="Your App Name"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE_GENERATE_WITH_php_artisan_key:generate_--show
APP_DEBUG=false
APP_URL=https://your-app.vercel.app

# Logging (Vercel specific)
LOG_CHANNEL=stderr
LOG_LEVEL=error

# Database - REQUIRED
# Use PlanetScale (MySQL), Neon (PostgreSQL), or Supabase (PostgreSQL)
DB_CONNECTION=mysql
DB_HOST=your-database-host
DB_PORT=3306
DB_DATABASE=your-database-name
DB_USERNAME=your-database-username
DB_PASSWORD=your-database-password

# Session & Cache (Serverless optimized)
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
CACHE_DRIVER=array
QUEUE_CONNECTION=sync

# Filesystem (Use S3 for uploads)
FILESYSTEM_DISK=public
# For S3 uploads, uncomment and configure:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=your-bucket-name

# Mail (Optional - use SendGrid, Mailgun, etc)
MAIL_MAILER=log
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_FROM_ADDRESS="noreply@yourdomain.com"
# MAIL_FROM_NAME="${APP_NAME}"

# Redis (Optional - use Upstash for better performance)
# REDIS_CLIENT=phpredis
# REDIS_URL=redis://default:password@endpoint.upstash.io:port
