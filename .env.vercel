# This file is deployed to Vercel and will be copied to .env
# Values will be replaced by Vercel environment variables at runtime

APP_NAME=TicketSystem
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
CACHE_DRIVER=array
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public
